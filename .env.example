# Environment Configuration Template
# Copy this file to .env.dev and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=Gaming Marketplace
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production

# =============================================================================
# SERVER
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_USER=marketplace_user
DB_PASSWORD=your-strong-password-here
DB_NAME=marketplace_db
DB_HOST=postgres
DB_PORT=5432

# For local development (if not using Docker)
# DATABASE_URL=postgresql+asyncpg://marketplace_user:password@localhost:5432/marketplace_db

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# For local development (if not using Docker)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CLOUDFLARE R2 (File Storage)
# =============================================================================
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=marketplace-files
R2_PUBLIC_URL=https://cdn.marketplace.com

# =============================================================================
# ONE SIGNAL (Push Notifications)
# =============================================================================
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Development: Allow all origins
CORS_ORIGINS=*

# Production: Specific origins only
# CORS_ORIGINS=https://marketplace.com,https://www.marketplace.com

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# =============================================================================
# CELERY (Background Tasks)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_ENABLE_REGISTRATION=true
FEATURE_ENABLE_LISTINGS=true
FEATURE_ENABLE_DEALS=true
FEATURE_ENABLE_CHAT=true
FEATURE_ENABLE_MEDIATORS=true
FEATURE_ENABLE_ADMIN=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Auto-reload on code changes
RELOAD=true

# Show SQL queries
DEBUG_SQL=false

# Enable debug toolbar
DEBUG_TOOLBAR=false
